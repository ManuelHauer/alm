# Copy to .env and fill in the values.
# Never commit .env — it is in .gitignore.

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# Local dev (native Postgres, see docs/DEPLOYMENT_NOTES.md):
#   DATABASE_URL=postgres://alm:alm@localhost:5432/alm
# Docker Compose (postgres service is named "postgres"):
#   DATABASE_URL=postgres://alm:${POSTGRES_PASSWORD}@postgres:5432/alm
DATABASE_URL=postgres://alm:alm@localhost:5432/alm

# ── Payload ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace_with_random_32_char_string

# ── Public server URL ──────────────────────────────────────────────────────
# Used for absolute URLs in OG images and sitemap.
# Local: http://localhost:3000
# Production: https://almproject.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Docker Compose only ────────────────────────────────────────────────────
# Password for the postgres service (not used in local native dev).
# POSTGRES_PASSWORD=changeme

# Host port for the app container (default: 3000).
# PORT=3000
